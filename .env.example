# Copy to .env for local development. All variables are optional in Stage 1
# (the sandbox tools need no credentials).
OPS_HOST=127.0.0.1
OPS_PORT=8000
OPS_APPROVAL_TTL_SECONDS=3600
# Set to persist state in Postgres. Unset -> fully in-memory (keyless demo).
# OPS_DATABASE_URL=postgresql://ops:ops@localhost:5432/ops
