# Copy to .env for local development. Everything is optional: with nothing set,
# the app runs fully in-memory over the keyless sandbox tools (no credentials).
OPS_HOST=127.0.0.1
OPS_PORT=8000
OPS_APPROVAL_TTL_SECONDS=3600
# Optional bearer token: set to require `Authorization: Bearer <key>` on the
# state-changing HTTP endpoints. Unset -> the API is open (demo).
# OPS_API_KEY=change-me
# Optional deployment tool allowlist (comma-separated). Empty -> all tools allowed.
# OPS_ALLOWED_TOOLS=email.search,calendar.find_free_time

# Persist state in Postgres. Unset -> fully in-memory (keyless demo).
# OPS_DATABASE_URL=postgresql://ops:ops@localhost:5432/ops

# Telegram bot (from @BotFather). Unset -> the bot is disabled.
# OPS_TELEGRAM_TOKEN=123456:abc
# Comma-separated allowlist of Telegram user ids. Empty -> open (public demo).
# OPS_TELEGRAM_ALLOWED_USERS=687812173
# Public-demo abuse guard: max requests per user per window. 0 -> no limit.
# OPS_TELEGRAM_RATE_LIMIT=5
# OPS_TELEGRAM_RATE_WINDOW_SECONDS=60

# LLM planner (OpenAI-compatible). All unset -> the deterministic demo planner.
# OPS_LLM_API_KEY=sk-...
# OPS_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPS_LLM_MODEL=google/gemini-2.5-flash

# Real Gmail/Calendar (Stage 4). Unset -> the keyless sandbox tools.
# OPS_GOOGLE_CLIENT_SECRETS=.secrets/google_client_secret.json
# OPS_GOOGLE_TOKEN_PATH=token.json

# n8n execution layer. All three set -> the gated, allowlisted n8n.run tool.
# OPS_N8N_BASE_URL=https://n8n.example.com
# OPS_N8N_SECRET=...
# OPS_N8N_WORKFLOWS=welcome-email,ticket-triage
